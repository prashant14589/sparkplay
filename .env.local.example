# Supabase (Database & Auth) - FREE TIER AVAILABLE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Payment Integration (international cards)
STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Create recurring prices in Stripe dashboard, then paste the price IDs here
STRIPE_FAMILY_PRICE_ID=price_your_family_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_price_id

# Razorpay (India — UPI, NetBanking, wallets, cards)
# Sign up at https://razorpay.com → get test/live keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# OpenAI API — for generating illustrated character assets (one-time script)
# Get your key at https://platform.openai.com/api-keys
# Run once: npm run generate:illustrations
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude API — for AI Story Quest generation
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: Add these in Phase 2+
# AWS S3 for file uploads
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET=your-s3-bucket-name

# Analytics (Phase 2+)
# NEXT_PUBLIC_GA_ID=your-google-analytics-id
